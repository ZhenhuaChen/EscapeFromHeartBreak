/* pages/progress/progress.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffeef8 0%, #e0f7ff 100%);
  padding: 40rpx;
  padding-bottom: calc(40rpx + 100rpx);
}

/* 日历 */
.calendar-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
}

.calendar-day {
  aspect-ratio: 1;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.calendar-day.completed {
  background: linear-gradient(135deg, #81d4fa 0%, #4fc3f7 100%);
}

.calendar-day.today {
  border: 3rpx solid #ff9dcd;
}

.day-number {
  font-size: 24rpx;
  color: #999;
}

.calendar-day.completed .day-number {
  color: #fff;
  font-weight: bold;
}

/* 详情弹窗遮罩 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

/* 底部弹出面板 */
.detail-panel {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 60rpx 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.detail-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.detail-body {
  flex: 1;
  padding: 30rpx 40rpx 0;
  width: auto;
}

/* 无数据状态 */
.detail-empty-all {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.detail-empty-icon {
  font-size: 80rpx;
}

.detail-empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 内容分区 */
.detail-section {
  margin-bottom: 36rpx;
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.detail-section-icon {
  font-size: 30rpx;
}

/* 任务条目 */
.detail-task-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
}

.detail-task-item.custom {
  background: #f0f9ff;
}

.detail-check {
  color: #4fc3f7;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.detail-task-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 情绪条目 */
.detail-emotion-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: #fff8fc;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
}

.emotion-emoji {
  font-size: 44rpx;
  flex-shrink: 0;
}

.emotion-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.emotion-time {
  font-size: 24rpx;
  color: #bbb;
  flex-shrink: 0;
}
