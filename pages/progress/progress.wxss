/* pages/progress/progress.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffeef8 0%, #e0f7ff 100%);
  padding: 40rpx;
  padding-bottom: calc(40rpx + 100rpx);
}

/* 日历 */
.calendar-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
}

.calendar-day {
  aspect-ratio: 1;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.calendar-day.completed {
  background: linear-gradient(135deg, #81d4fa 0%, #4fc3f7 100%);
}

.calendar-day.today {
  border: 3rpx solid #ff9dcd;
}

.day-number {
  font-size: 24rpx;
  color: #999;
}

.calendar-day.completed .day-number {
  color: #fff;
  font-weight: bold;
}
