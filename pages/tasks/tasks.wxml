<!--tasks.wxml-->
<navigation-bar title="任务打卡" background="linear-gradient(90deg, #ffc0e0 0%, #ffe5f0 100%)" color="#333" back="{{false}}"></navigation-bar>

<view class="container">
  <view class="header">
    <view class="title">今日任务</view>
    <view class="date">{{todayDate}}</view>
  </view>

  <view class="daily-task-card">
    <view class="task-header">
      <text class="task-day">系统任务</text>
      <text class="task-status {{todayTaskCompleted ? 'completed' : ''}}">{{todayTaskCompleted ? '全部完成' : '进行中'}}</text>
    </view>
    <view class="today-tasks-list">
      <view
        wx:for="{{tasksList}}"
        wx:key="id"
        class="today-task-item {{item.completed ? 'completed' : ''}}"
        bindtap="handleTaskTap"
        data-task-id="{{item.id}}"
      >
        <view class="task-checkbox {{item.completed ? 'checked' : ''}}"
>
          <text wx:if="{{item.completed}}" class="check-icon">✓</text>
        </view>
        <view class="task-name">{{item.title}}</view>
      </view>
    </view>
    <view wx:if="{{todayTaskCompleted}}" class="completed-time">
      完成时间：{{completedTimeStr}}
    </view>
  </view>

  <view class="custom-tasks-section">
    <view class="section-header">
      <view class="section-title">我的待办</view>
      <view wx:if="{{customTasks.length < 5}}" class="add-task-btn" bindtap="showAddTaskDialog">
        <text class="add-icon">+</text>
      </view>
    </view>

    <view wx:if="{{customTasks.length === 0}}" class="empty-tasks">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有自定义任务</text>
      <text class="empty-tip">点击右上角 + 添加待办事项</text>
    </view>

    <view wx:else class="custom-tasks-list">
      <view
        wx:for="{{customTasks}}"
        wx:key="id"
        class="custom-task-item {{item.completed ? 'completed' : ''}}"
      >
        <view class="task-checkbox {{item.completed ? 'checked' : ''}}" bindtap="toggleCustomTask" data-id="{{item.id}}">
          <text wx:if="{{item.completed}}" class="check-icon">✓</text>
        </view>
        <view class="task-content">
          <view class="task-text">{{item.content}}</view>
          <view wx:if="{{item.completed}}" class="task-time">完成于 {{item.completedTimeStr}}</view>
        </view>
        <view class="task-delete" bindtap="deleteCustomTask" data-id="{{item.id}}">
          <text>×</text>
        </view>
      </view>
    </view>

    <view class="task-count">{{customTasks.length}}/5</view>
  </view>
</view>

<!-- 鼓励弹窗 -->
<view wx:if="{{showEncouragement}}" class="encouragement-modal" bindtap="closeEncouragement">
  <view class="encouragement-content" catchtap="stopPropagation">
    <view class="encouragement-icon">🎉</view>
    <view class="encouragement-title">任务完成！</view>
    <view class="encouragement-message">{{encouragementMessage}}</view>
    <button class="encouragement-btn" bindtap="closeEncouragement">继续加油</button>
  </view>
</view>

<!-- 添加任务弹窗 -->
<view wx:if="{{showAddDialog}}" class="add-task-modal" bindtap="closeAddDialog">
  <view class="add-task-content" catchtap="stopPropagation">
    <view class="dialog-title">添加待办事项</view>
    <textarea
      class="task-input"
      placeholder="输入待办事项..."
      maxlength="50"
      value="{{newTaskContent}}"
      bindinput="handleTaskInput"
      auto-focus
    />
    <view class="dialog-buttons">
      <button class="cancel-btn" bindtap="closeAddDialog">取消</button>
      <button class="confirm-btn" bindtap="addCustomTask">确定</button>
    </view>
  </view>
</view>
