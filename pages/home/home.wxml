<!--home.wxml-->
<navigation-bar title="失恋戒断" background="linear-gradient(90deg, #ffc0e0 0%, #ffe5f0 100%)" color="#333" back="{{false}}"></navigation-bar>

<scroll-view class="container" scroll-y="true">
  <!-- 顶部状态卡片 -->
  <view class="status-card">
    <view class="greeting">你好，{{userProfile.nickname}}</view>
    <view class="recovery-plan">
      <text class="plan-text">{{recoveryDays}}天恢复计划</text>
    </view>
    <view class="days-info">
      <view class="days-item">
        <text class="days-number">{{detoxDays}}</text>
        <text class="days-label">已坚持</text>
      </view>
      <view class="days-item">
        <text class="days-number">{{recoveryDays - detoxDays}}</text>
        <text class="days-label">剩余天数</text>
      </view>
      <view class="days-item">
        <text class="days-number">{{completedTasksCount}}/{{totalTasksCount}}</text>
        <text class="days-label">完成任务</text>
      </view>
    </view>
    <view class="progress-section">
      <view class="progress-header">
        <text class="progress-tip">{{progressTip}}</text>
        <text class="progress-percent">{{progressPercent}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
    </view>
  </view>



  <!-- 任务列表 -->
  <view class="tasks-section">
    <view class="section-title">今日任务 (Day {{detoxDays}})</view>
    <view wx:if="{{tasksList.length === 0}}" class="no-tasks">
      <text class="no-tasks-icon">🎉</text>
      <text class="no-tasks-text">今天没有新任务</text>
      <text class="no-tasks-tip">好好享受轻松的一天吧</text>
    </view>
    <view wx:else class="tasks-list">
      <view
        wx:for="{{tasksList}}"
        wx:key="id"
        class="task-item {{item.completed ? 'completed' : ''}}"
      >
        <view class="task-left">
          <view class="task-checkbox {{item.completed ? 'checked' : ''}}" bindtap="handleToggleTask" data-id="{{item.id}}">
            <text wx:if="{{item.completed}}" class="check-icon">✓</text>
          </view>
          <view class="task-info">
            <view class="task-title">
              <text>{{item.title}}</text>
            </view>
            <view class="task-desc">{{item.desc}}</view>
            <view wx:if="{{item.completed}}" class="task-date">完成于 {{item.dateStr}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
